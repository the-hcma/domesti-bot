{
  "name": "@domesti-bot/web",
  "version": "0.0.0",
  "private": true,
  "description": "Browser bundle for the domesti-bot HTTP API.",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run typecheck && pnpm run build"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
