{
  "name": "@domesti-bot/web",
  "version": "0.0.0",
  "private": true,
  "description": "Browser bundle for the domesti-bot HTTP API.",
  "type": "module",
  "scripts": {
    "build": "node scripts/rasterize-pwa-icons.mjs && node build.mjs",
    "watch": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run typecheck && pnpm run build"
  },
  "devDependencies": {
    "@types/leaflet": "1.9.21",
    "esbuild": "0.28.1",
    "sharp": "0.35.3",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "dependencies": {
    "leaflet": "1.9.4"
  }
}
