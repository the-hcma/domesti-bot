    {
      "id": "away-garage-open-alert",
      "label": "Email when a garage door is open and everyone away 20+ min",
      "enabled": true,
      "triggers": [
        "dwell_satisfied"
      ],
      "cooldown_s": 0,
      "min_location_accuracy_m": 50,
      "notify_on_fire": true,
      "notification_emails": [
        "operator@example.com",
        "resident@example.com"
      ],
      "conditions": {
        "all": [
          {
            "type": "users_outside_geofence_for_s",
            "geofence_id": "house",
            "user_ids": [
              "henrique",
              "kristen"
            ],
            "min_outside_s": 1200
          },
          {
            "type": "devices_any_in_state_for_s",
            "state": "open",
            "min_duration_s": 1200,
