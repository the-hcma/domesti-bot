{
  "version": 1,
  "device_id_resolution": "preferred_label",
  "_notes": [
    "Copy this file to automation-rules.json in the repo/server root (same directory as domesti-bot.config.json).",
    "device_id values are tile/REPL display names; the evaluator resolves them to Kasa hosts, Sonos zone labels, Vizio TV labels, or Tailwind door ids.",
    "Geofence ids must match Automations → Geofences (house is typical for home; west-point for West Point).",
    "SMTP must be configured under Automations → Mail for notification emails to send.",
    "Rule 1 fires when Henrique OR Kristen enters house after sunset (arrival edge, not merely present at sunset).",
    "Rule 2 (evening-lights-off-both-home) runs every 10 min after sunset: when both have been home 10+ min and either arrival light is still on, turn both off.",
    "Rule 3 (evening-interior-lights-on-anyone-home) runs every 10 min after sunset: when either person is home, turn on interior lamps once per local day.",
    "Rule 4 (away-shutdown-everyone-outside-20m) runs every 10 min: when Henrique AND Kristen have been outside house 20+ min and any listed light/media device is still on, turn them off (garage doors are not closed).",
    "Rule 5 (away-garage-open-alert) runs every 10 min: when both have been outside house 20+ min and any garage door is open, email hcma@hcma.info and kristen@kristenmather.com."
  ],
  "settings_location": {
    "lat": 41.194072,
    "lon": -73.8883254,
    "timezone": "America/New_York",
    "home_label": "Home",
    "wifi_home_presence_enabled": true,
    "wifi_home_geofence_id": "house"
  },
  "rules": [
    {
      "id": "evening-arrival-home-lights",
      "label": "Evening arrival — front + garage lights",
      "enabled": true,
      "trigger": "edge_true",
      "cooldown_s": 300,
      "min_location_accuracy_m": 50,
      "accuracy_edge_grace_s": 120,
      "notify_on_fire": true,
      "notification_emails": ["github@hcma.info"],
      "conditions": {
        "all": [
          {
            "type": "after_sunset",
            "offset_minutes": 0,
            "window_end": "midnight"
          },
          {
            "type": "any",
            "conditions": [
              {
                "type": "users_inside_geofence",
                "geofence_id": "house",
                "user_ids": ["henrique"]
              },
              {
                "type": "users_inside_geofence",
                "geofence_id": "house",
                "user_ids": ["kristen"]
              }
            ]
          }
        ]
      },
      "device_actions": [
        {
          "family_id": "kasa",
          "device_id": "Front door lights",
          "action": "turn_on"
        },
        {
          "family_id": "kasa",
          "device_id": "Garage",
          "action": "turn_on"
        },
        {
          "family_id": "kasa",
          "device_id": "Garage outside lights",
          "action": "turn_on"
        }
      ]
    },
    {
      "id": "evening-lights-off-both-home",
      "label": "Turn off arrival lights when both home 10+ min after sunset",
      "enabled": true,
      "trigger": "scheduled",
      "schedule_cron": "*/10 * * * *",
      "cooldown_s": 300,
      "min_location_accuracy_m": 50,
      "accuracy_edge_grace_s": 120,
      "notify_on_fire": false,
      "conditions": {
        "all": [
          {
            "type": "after_sunset",
            "offset_minutes": 0,
            "window_end": "midnight"
          },
          {
            "type": "users_inside_geofence_for_s",
            "geofence_id": "house",
            "user_ids": ["henrique", "kristen"],
            "min_inside_s": 600
          },
          {
            "type": "devices_any_on",
            "devices": [
              {
                "family_id": "kasa",
                "device_id": "Front door lights"
              },
              {
                "family_id": "kasa",
                "device_id": "Garage outside lights"
              }
            ]
          }
        ]
      },
      "device_actions": [
        {
          "family_id": "kasa",
          "device_id": "Front door lights",
          "action": "turn_off"
        },
        {
          "family_id": "kasa",
          "device_id": "Garage outside lights",
          "action": "turn_off"
        }
      ]
    },
    {
      "id": "evening-interior-lights-on-anyone-home",
      "label": "Turn on interior lamps when anyone home after sunset (once per day)",
      "enabled": true,
      "trigger": "scheduled",
      "schedule_cron": "*/10 * * * *",
      "fire_once_per_local_day": true,
      "cooldown_s": 300,
      "min_location_accuracy_m": 50,
      "notify_on_fire": false,
      "conditions": {
        "all": [
          {
            "type": "after_sunset",
            "offset_minutes": 0,
            "window_end": "midnight"
          },
          {
            "type": "any",
            "conditions": [
              {
                "type": "users_inside_geofence",
                "geofence_id": "house",
                "user_ids": ["henrique"]
              },
              {
                "type": "users_inside_geofence",
                "geofence_id": "house",
                "user_ids": ["kristen"]
              }
            ]
          }
        ]
      },
      "device_actions": [
        {
          "family_id": "kasa",
          "device_id": "Kitchen lamp",
          "action": "turn_on"
        },
        {
          "family_id": "kasa",
          "device_id": "Living room lamp",
          "action": "turn_on"
        },
        {
          "family_id": "kasa",
          "device_id": "Living room lamp2",
          "action": "turn_on"
        }
      ]
    },
    {
      "id": "away-shutdown-everyone-outside-20m",
      "label": "Turn off lights and media when everyone away 20+ min",
      "enabled": true,
      "trigger": "scheduled",
      "schedule_cron": "*/10 * * * *",
      "cooldown_s": 300,
      "min_location_accuracy_m": 50,
      "notify_on_fire": false,
      "conditions": {
        "all": [
          {
            "type": "users_outside_geofence_for_s",
            "geofence_id": "house",
            "user_ids": ["henrique", "kristen"],
            "min_outside_s": 1200
          },
          {
            "type": "devices_any_on",
            "devices": [
              { "family_id": "kasa", "device_id": "Front door lights" },
              { "family_id": "kasa", "device_id": "Garage" },
              { "family_id": "kasa", "device_id": "Garage outside lights" },
              { "family_id": "kasa", "device_id": "Kitchen lamp" },
              { "family_id": "kasa", "device_id": "Living room lamp" },
              { "family_id": "kasa", "device_id": "Living room lamp2" },
              { "family_id": "sonos", "device_id": "Kitchen" },
              { "family_id": "sonos", "device_id": "Living Room" },
              { "family_id": "sonos", "device_id": "Master Bedroom" },
              { "family_id": "vizio", "device_id": "Kitchen TV" }
            ]
          }
        ]
      },
      "device_actions": [
        { "family_id": "kasa", "device_id": "Front door lights", "action": "turn_off" },
        { "family_id": "kasa", "device_id": "Garage", "action": "turn_off" },
        { "family_id": "kasa", "device_id": "Garage outside lights", "action": "turn_off" },
        { "family_id": "kasa", "device_id": "Kitchen lamp", "action": "turn_off" },
        { "family_id": "kasa", "device_id": "Living room lamp", "action": "turn_off" },
        { "family_id": "kasa", "device_id": "Living room lamp2", "action": "turn_off" },
        { "family_id": "sonos", "device_id": "Kitchen", "action": "pause" },
        { "family_id": "sonos", "device_id": "Living Room", "action": "pause" },
        { "family_id": "sonos", "device_id": "Master Bedroom", "action": "pause" },
        { "family_id": "vizio", "device_id": "Kitchen TV", "action": "turn_off" }
      ]
    },
    {
      "id": "away-garage-open-alert",
      "label": "Email when a garage door is open and everyone away 20+ min",
      "enabled": true,
      "trigger": "scheduled",
      "schedule_cron": "*/10 * * * *",
      "cooldown_s": 1800,
      "min_location_accuracy_m": 50,
      "notify_on_fire": true,
      "notification_emails": [
        "hcma@hcma.info",
        "kristen@kristenmather.com"
      ],
      "conditions": {
        "all": [
          {
            "type": "users_outside_geofence_for_s",
            "geofence_id": "house",
            "user_ids": ["henrique", "kristen"],
            "min_outside_s": 1200
          },
          {
            "type": "devices_any_open",
            "devices": [
              { "family_id": "tailwind", "device_id": "Left" },
              { "family_id": "tailwind", "device_id": "Right" }
            ]
          }
        ]
      },
      "device_actions": []
    },
    {
      "id": "kristen-west-point-arrive",
      "label": "Kristen arrived at West Point",
      "enabled": true,
      "trigger": "edge_true",
      "cooldown_s": 120,
      "min_location_accuracy_m": 50,
      "notify_on_fire": true,
      "notification_emails": ["github@hcma.info"],
      "conditions": {
        "all": [
          {
            "type": "users_inside_geofence",
            "geofence_id": "west-point",
            "user_ids": ["kristen"]
          }
        ]
      },
      "device_actions": []
    },
    {
      "id": "kristen-west-point-leave",
      "label": "Kristen left West Point",
      "enabled": true,
      "trigger": "edge_true",
      "cooldown_s": 120,
      "min_location_accuracy_m": 50,
      "notify_on_fire": true,
      "notification_emails": ["github@hcma.info"],
      "conditions": {
        "all": [
          {
            "type": "users_outside_geofence",
            "geofence_id": "west-point",
            "user_ids": ["kristen"]
          }
        ]
      },
      "device_actions": []
    }
  ]
}
