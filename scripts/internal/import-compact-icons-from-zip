#!/usr/bin/env python3
"""Import Illustrator-exported compact tile SVGs from a zip into ``icons/compact/``.

Strips canvas frames, inner mattes, bottom word labels, and black fills; keeps white
line art as ``currentColor`` on a transparent background. Copies ``room_laundry.svg``
to ``room_basement.svg`` when the zip has no basement artwork.

Usage:
  ./scripts/internal/import-compact-icons-from-zip /tmp/icons_svg.zip
  ./scripts/internal/import-compact-icons-from-zip /tmp/icons_svg.zip --dest path/to/compact
"""

from __future__ import annotations

import argparse
import os
import shutil
import sys
import zipfile
from pathlib import Path
from tempfile import TemporaryDirectory

_REPO_ROOT = Path(__file__).resolve().parents[2]
if str(_REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(_REPO_ROOT))

from app.compact_icon_svg_process import process_compact_icon_svg_bytes
_DEFAULT_DEST = _REPO_ROOT / "app" / "api" / "static" / "icons" / "compact"
_BASEMENT_FALLBACK_STEM = "room_laundry"


def _ensure_uv() -> None:
    if os.environ.get("UV_ACTIVE") or "/.venv/" in (sys.executable or ""):
        return
    uv = shutil.which("uv")
    if uv:
        os.execv(uv, [uv, "run", sys.argv[0], *sys.argv[1:]])


def _import_zip(zip_path: Path, dest: Path) -> list[str]:
    dest.mkdir(parents=True, exist_ok=True)
    written: list[str] = []
    with TemporaryDirectory(prefix="compact-icons-import-") as tmp:
        tmp_dir = Path(tmp)
        with zipfile.ZipFile(zip_path) as archive:
            archive.extractall(tmp_dir)
        stems = sorted(
            {
                member.stem
                for member in tmp_dir.rglob("*.svg")
                if member.is_file() and not member.name.startswith(".")
            }
        )
        for stem in stems:
            source = next(tmp_dir.rglob(f"{stem}.svg"))
            processed = process_compact_icon_svg_bytes(source.read_bytes())
            out_path = dest / f"{stem}.svg"
            out_path.write_bytes(processed)
            written.append(stem)
        if "room_basement" not in stems:
            fallback = dest / f"{_BASEMENT_FALLBACK_STEM}.svg"
            if not fallback.is_file():
                msg = (
                    f"Expected {_BASEMENT_FALLBACK_STEM}.svg in zip to derive room_basement"
                )
                raise SystemExit(msg)
            basement_path = dest / "room_basement.svg"
            basement_path.write_bytes(fallback.read_bytes())
            written.append("room_basement")
    return sorted(set(written))


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "zip_path",
        type=Path,
        help="Path to icons_svg.zip (flat *.svg members)",
    )
    parser.add_argument(
        "--dest",
        type=Path,
        default=_DEFAULT_DEST,
        help=f"Output directory (default: {_DEFAULT_DEST})",
    )
    args = parser.parse_args()
    zip_path = args.zip_path.expanduser().resolve()
    if not zip_path.is_file():
        print(f"Expected a zip file, got {zip_path!s}", file=sys.stderr)
        return 2
    dest = args.dest.expanduser().resolve()
    written = _import_zip(zip_path, dest)
    print(f"Wrote {len(written)} SVG(s) to {dest}")
    for stem in written:
        print(f"  {stem}.svg")
    return 0


if __name__ == "__main__":
    _ensure_uv()
    raise SystemExit(main())
