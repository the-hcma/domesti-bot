#!/usr/bin/env bash
# Poll GitHub for Copilot pull-request review state and resolve review threads.
#
# Subcommands:
#   status              JSON: head SHA, requested, fresh review, open thread count
#   request             Ask Copilot to review (idempotent)
#   wait                Block until Copilot posts a review for the current head
#   list-threads        Print Copilot threads still needing a human reply (JSON)
#   check               Exit 0 when satisfied; 3 unaddressed threads; 4 merge not ready; 0 if PR merged
#   restack             Sync and restack when mergeStateStatus is BEHIND
#   resolve-thread      Resolve one thread by GraphQL node id
#   resolve-addressed   Resolve Copilot threads that already have a human reply
#   email-success       Email operator that the PR is ready for human review
#   email-failure       Email operator that the Copilot loop timed out
#
# Typical agent loop (see .cursor/rules/pr-ship-and-review.mdc):
#   1. request → wait → list-threads
#   2. fix code, reply on-thread, resolve-thread (or resolve-addressed)
#   3. push new head → request → wait → … until list-threads is empty
#   4. email-success   (or email-failure when the caller hits its total deadline)
set -euo pipefail

readonly default_repo='the-hcma/domesti-bot'
readonly default_wait_timeout_s=300
readonly default_poll_interval_s=15
readonly from_addr='domesti-bot@hcma.info'
readonly to_addr='github@hcma.info'

usage() {
  cat <<'EOF'
Usage: scripts/wait-for-copilot-review <command> [options]

Commands:
  status [--pr N] [--repo OWNER/NAME]
  request [--pr N] [--repo OWNER/NAME]
  wait [--pr N] [--repo OWNER/NAME] [--timeout SECONDS] [--poll-interval SECONDS]
  list-threads [--pr N] [--repo OWNER/NAME]
  check [--pr N] [--repo OWNER/NAME]
  restack [--pr N] [--repo OWNER/NAME]
  resolve-thread --thread-id ID
  resolve-addressed [--pr N] [--repo OWNER/NAME]
  email-success [--pr N] [--repo OWNER/NAME]
  email-failure [--pr N] [--repo OWNER/NAME] [--reason TEXT]

Environment:
  DOMESTI_GITHUB_REPO   default repo (OWNER/NAME)
  DOMESTI_PR_NUMBER     default PR number when --pr is omitted

Exit codes:
  0  success (including PR already merged — loop complete)
  1  usage / prerequisite error
  2  timed out waiting for Copilot review (wait) or no fresh review on head (check)
  3  Copilot threads still lack a human reply (list-threads output on stdout)
  4  mergeStateStatus is BEHIND/DIRTY/CONFLICTING (run restack or fix conflicts)
EOF
}

die() {
  printf 'wait-for-copilot-review: %s\n' "$*" >&2
  exit 1
}

require_cmd() {
  local -r name="$1"
  command -v "${name}" >/dev/null 2>&1 || die "required command not found: ${name}"
}

require_option_value() {
  local -r flag="$1"
  local -r value="${2:-}"
  if [[ -z "${value}" || "${value}" == --* ]]; then
    die "option ${flag} requires a value"
  fi
  printf '%s' "${value}"
}

repo_parts() {
  local -r repo="${1:-}"
  local owner name
  if [[ "${repo}" != */* ]] || [[ "${repo}" == */*/* ]]; then
    die "expected OWNER/NAME repo, got ${repo@Q}"
  fi
  owner="${repo%%/*}"
  name="${repo#*/}"
  if [[ -z "${owner}" || -z "${name}" ]]; then
    die "expected OWNER/NAME repo, got ${repo@Q}"
  fi
  printf '%s %s\n' "${owner}" "${name}"
}

resolve_repo() {
  local repo="${DOMESTI_GITHUB_REPO:-${default_repo}}"
  if [[ -n "${1:-}" ]]; then
    repo="$1"
  fi
  printf '%s' "${repo}"
}

resolve_pr() {
  local pr="${DOMESTI_PR_NUMBER:-}"
  local repo
  if [[ -n "${1:-}" ]]; then
    pr="$1"
  fi
  repo="$(resolve_repo "${2:-}")"
  if [[ -z "${pr}" ]]; then
    require_cmd gh
    pr="$(gh pr view --repo "${repo}" --json number --jq '.number' 2>/dev/null || true)"
  fi
  if [[ -z "${pr}" ]]; then
    die "PR number required (pass --pr N or set DOMESTI_PR_NUMBER)"
  fi
  validate_positive_int --pr "${pr}"
  printf '%s' "${pr}"
}

validate_positive_int() {
  local -r flag="$1"
  local -r value="$2"
  if [[ ! "${value}" =~ ^[0-9]+$ ]]; then
    die "option ${flag} requires a positive integer, got ${value@Q}"
  fi
  if (( 10#${value} < 1 )); then
    die "option ${flag} requires a positive integer, got ${value@Q}"
  fi
}

assert_review_requests_complete() {
  local -r snapshot="$1"
  if printf '%s' "${snapshot}" | jq -e '.data.repository.pullRequest.reviewRequests.pageInfo.hasNextPage == true' >/dev/null; then
    die 'reviewRequests connection truncated (first:10); cannot trust request state'
  fi
}

assert_reviews_complete() {
  local -r snapshot="$1"
  if printf '%s' "${snapshot}" | jq -e '.data.repository.pullRequest.reviews.pageInfo.hasPreviousPage == true' >/dev/null; then
    die 'reviews connection truncated (last:100); cannot trust freshness'
  fi
}

assert_checkout_matches_repo() {
  local -r repo="$1"
  local owner name origin_url
  read -r owner name < <(repo_parts "${repo}")
  origin_url="$(git remote get-url origin 2>/dev/null || true)"
  if [[ -z "${origin_url}" ]]; then
    die 'current checkout has no origin remote'
  fi
  if [[ "${origin_url}" != *"github.com/${owner}/${name}"* ]] \
    && [[ "${origin_url}" != *"github.com:${owner}/${name}"* ]]; then
    die "current checkout origin ${origin_url@Q} does not match repo ${repo@Q}"
  fi
}

assert_not_primary_worktree() {
  local primary cwd
  require_cmd git
  primary="$(git worktree list --porcelain | awk '/^worktree / { sub(/^worktree /, ""); print; exit }')"
  cwd="$(git rev-parse --show-toplevel)"
  if [[ -z "${primary}" || -z "${cwd}" ]]; then
    die 'could not determine git worktree paths'
  fi
  if [[ "${cwd}" == "${primary}" ]]; then
    die 'restack runs gt sync/restack/submit, which are forbidden in the primary (main) worktree — run from .worktrees/<stack>-wt'
  fi
}

assert_review_threads_complete() {
  local -r snapshot="$1"
  if printf '%s' "${snapshot}" | jq -e '.data.repository.pullRequest.reviewThreads.pageInfo.hasNextPage == true' >/dev/null; then
    die 'reviewThreads connection truncated (first:100); cannot trust thread counts'
  fi
  if printf '%s' "${snapshot}" | jq -e '
      [.data.repository.pullRequest.reviewThreads.nodes[]
        | .comments.pageInfo.hasNextPage] | any' >/dev/null; then
    die 'reviewThread comments truncated (first:100); cannot trust reply detection'
  fi
}

assert_snapshot_complete() {
  assert_review_requests_complete "$1"
  assert_reviews_complete "$1"
  assert_review_threads_complete "$1"
}

graphql_pr_snapshot() {
  local -r owner="$1"
  local -r name="$2"
  local -r pr="$3"
  # shellcheck disable=SC2016
  gh api graphql -f query='
query($owner:String!, $name:String!, $number:Int!) {
  repository(owner:$owner, name:$name) {
    pullRequest(number:$number) {
      number
      title
      url
      headRefOid
      reviewRequests(first:10) {
        pageInfo { hasNextPage }
        nodes { requestedReviewer { ... on User { login } ... on Bot { login } ... on Team { slug } } }
      }
      reviews(last:100) {
        pageInfo { hasPreviousPage }
        nodes {
          author { login }
          state
          submittedAt
          commit { oid }
        }
      }
      reviewThreads(first:100) {
        pageInfo { hasNextPage }
        nodes {
          id
          isResolved
          comments(first:100) {
            pageInfo { hasNextPage }
            nodes { databaseId url author { __typename login } body path line createdAt }
          }
        }
      }
    }
  }
}' -f owner="${owner}" -f name="${name}" -F number="${pr}"
}

graphql_request_snapshot() {
  local -r owner="$1"
  local -r name="$2"
  local -r pr="$3"
  # shellcheck disable=SC2016
  gh api graphql -f query='
query($owner:String!, $name:String!, $number:Int!) {
  repository(owner:$owner, name:$name) {
    pullRequest(number:$number) {
      reviewRequests(first:10) {
        pageInfo { hasNextPage }
        nodes { requestedReviewer { ... on User { login } ... on Bot { login } ... on Team { slug } } }
      }
    }
  }
}' -f owner="${owner}" -f name="${name}" -F number="${pr}"
}

graphql_wait_snapshot() {
  local -r owner="$1"
  local -r name="$2"
  local -r pr="$3"
  # shellcheck disable=SC2016
  gh api graphql -f query='
query($owner:String!, $name:String!, $number:Int!) {
  repository(owner:$owner, name:$name) {
    pullRequest(number:$number) {
      headRefOid
      reviews(last:100) {
        pageInfo { hasPreviousPage }
        nodes {
          author { login }
          state
          commit { oid }
        }
      }
    }
  }
}' -f owner="${owner}" -f name="${name}" -F number="${pr}"
}

copilot_requested() {
  local -r owner="$1"
  local -r name="$2"
  local -r pr="$3"
  local snapshot
  snapshot="$(graphql_request_snapshot "${owner}" "${name}" "${pr}")"
  assert_review_requests_complete "${snapshot}"
  printf '%s' "${snapshot}" | jq -e '[.data.repository.pullRequest.reviewRequests.nodes[]
      | .requestedReviewer | (.login // .slug // "")
      | select(test("copilot";"i"))] | length > 0' >/dev/null
}

fresh_copilot_review_from_snapshot() {
  local -r snapshot="$1"
  local -r head="$2"
  assert_reviews_complete "${snapshot}"
  printf '%s' "${snapshot}" | jq -e --arg head "${head}" '
    [.data.repository.pullRequest.reviews.nodes[]
      | select((.author.login // "") | test("copilot";"i"))
      | select(.state != "PENDING")
      | select(.commit.oid == $head)] | length > 0' >/dev/null
}

cmd_request() {
  local repo pr owner name
  repo="$(resolve_repo "${1:-}")"
  read -r owner name < <(repo_parts "${repo}")
  pr="$(resolve_pr "${2:-}" "${repo}")"
  require_cmd gh
  require_cmd jq
  if pr_is_merged "${repo}" "${pr}"; then
    printf 'PR #%s is already merged — skipping Copilot request\n' "${pr}" >&2
    return 0
  fi
  if copilot_requested "${owner}" "${name}" "${pr}"; then
    printf 'Copilot review already requested on PR #%s\n' "${pr}" >&2
    return 0
  fi
  gh pr edit "${pr}" --repo "${repo}" --add-reviewer @copilot >/dev/null
  printf 'Requested Copilot review on PR #%s\n' "${pr}" >&2
}

cmd_status() {
  local repo pr owner name snapshot
  repo="$(resolve_repo "${1:-}")"
  read -r owner name < <(repo_parts "${repo}")
  pr="$(resolve_pr "${2:-}" "${repo}")"
  require_cmd gh
  require_cmd jq
  snapshot="$(graphql_pr_snapshot "${owner}" "${name}" "${pr}")"
  assert_snapshot_complete "${snapshot}"
  status_json_from_snapshot "${snapshot}" "${repo}" "${pr}"
}

status_json_from_snapshot() {
  local -r snapshot="$1"
  local -r repo="$2"
  local -r pr="$3"
  local head requested fresh open unaddressed merge_json merge_state mergeable merge_ready pr_state pr_merged
  assert_reviews_complete "${snapshot}"
  head="$(printf '%s' "${snapshot}" | jq -r '.data.repository.pullRequest.headRefOid')"
  if printf '%s' "${snapshot}" | jq -e '[.data.repository.pullRequest.reviewRequests.nodes[]
      | .requestedReviewer | (.login // .slug // "")
      | select(test("copilot";"i"))] | length > 0' >/dev/null; then
    requested=true
  else
    requested=false
  fi
  if printf '%s' "${snapshot}" | jq -e --arg head "${head}" '
      [.data.repository.pullRequest.reviews.nodes[]
        | select((.author.login // "") | test("copilot";"i"))
        | select(.state != "PENDING")
        | select(.commit.oid == $head)] | length > 0' >/dev/null; then
    fresh=true
  else
    fresh=false
  fi
  open="$(printf '%s' "${snapshot}" | jq '[.data.repository.pullRequest.reviewThreads.nodes[]
    | select(.isResolved == false)
    | select((.comments.nodes[0].author.login // "") | test("copilot";"i"))] | length')"
  unaddressed="$(printf '%s' "${snapshot}" | jq '[.data.repository.pullRequest.reviewThreads.nodes[]
    | select((.comments.nodes[0].author.login // "") | test("copilot";"i"))
    | select(any(.comments.nodes[1:][]; .author.__typename == "User") | not)] | length')"
  merge_json="$(pr_merge_json "${repo}" "${pr}")"
  pr_state="$(printf '%s' "${merge_json}" | jq -r '.state')"
  if [[ "${pr_state}" == 'MERGED' ]]; then
    pr_merged=true
  else
    pr_merged=false
  fi
  merge_state="$(printf '%s' "${merge_json}" | jq -r '.mergeStateStatus')"
  mergeable="$(printf '%s' "${merge_json}" | jq -r '.mergeable')"
  if merge_state_ready "${merge_state}"; then
    merge_ready=true
  else
    merge_ready=false
  fi
  jq -n \
    --arg pr "${pr}" \
    --arg repo "${repo}" \
    --arg head "${head}" \
    --arg merge_state_status "${merge_state}" \
    --arg pr_state "${pr_state}" \
    --arg mergeable "${mergeable}" \
    --argjson merge_ready "${merge_ready}" \
    --argjson pr_merged "${pr_merged}" \
    --argjson requested "${requested}" \
    --argjson fresh_review_on_head "${fresh}" \
    --argjson open_copilot_threads "${open}" \
    --argjson unaddressed_copilot_threads "${unaddressed}" \
    '{
      pr: ($pr | tonumber),
      repo: $repo,
      head_sha: $head,
      pr_state: $pr_state,
      pr_merged: $pr_merged,
      merge_state_status: $merge_state_status,
      mergeable: $mergeable,
      merge_ready: $merge_ready,
      copilot_requested: $requested,
      fresh_review_on_head: $fresh_review_on_head,
      open_copilot_threads: $open_copilot_threads,
      unaddressed_copilot_threads: $unaddressed_copilot_threads,
      pending: (($pr_merged | not) and ($fresh_review_on_head | not)),
      satisfied: ($pr_merged or ($fresh_review_on_head and ($unaddressed_copilot_threads == 0) and $merge_ready))
    }'
}

cmd_wait() {
  local repo pr timeout interval owner name head started snapshot
  repo="$(resolve_repo "${1:-}")"
  read -r owner name < <(repo_parts "${repo}")
  pr="$(resolve_pr "${2:-}" "${repo}")"
  timeout="${3:-${default_wait_timeout_s}}"
  interval="${4:-${default_poll_interval_s}}"
  validate_positive_int --timeout "${timeout}"
  validate_positive_int --poll-interval "${interval}"
  require_cmd gh
  require_cmd jq
  started="$(date +%s)"
  while true; do
    if pr_is_merged "${repo}" "${pr}"; then
      printf 'PR #%s is already merged — stopping wait\n' "${pr}" >&2
      return 0
    fi
    snapshot="$(graphql_wait_snapshot "${owner}" "${name}" "${pr}")"
    head="$(printf '%s' "${snapshot}" | jq -r '.data.repository.pullRequest.headRefOid')"
    if fresh_copilot_review_from_snapshot "${snapshot}" "${head}"; then
      printf 'Copilot review posted for head %s (PR #%s)\n' "${head:0:7}" "${pr}" >&2
      return 0
    fi
    if (( $(date +%s) - started >= timeout )); then
      printf 'wait-for-copilot-review: timed out after %ss waiting for Copilot review on head %s\n' \
        "${timeout}" "${head:0:7}" >&2
      return 2
    fi
    printf 'Waiting for Copilot review on PR #%s (head %s)…\n' "${pr}" "${head:0:7}" >&2
    sleep "${interval}"
  done
}

cmd_list_threads() {
  local repo pr owner name snapshot
  repo="$(resolve_repo "${1:-}")"
  read -r owner name < <(repo_parts "${repo}")
  pr="$(resolve_pr "${2:-}" "${repo}")"
  require_cmd gh
  require_cmd jq
  snapshot="$(graphql_pr_snapshot "${owner}" "${name}" "${pr}")"
  assert_snapshot_complete "${snapshot}"
  threads_json_from_snapshot "${snapshot}"
}

threads_json_from_snapshot() {
  local -r snapshot="$1"
  printf '%s' "${snapshot}" \
    | jq '[.data.repository.pullRequest.reviewThreads.nodes[]
      | select((.comments.nodes[0].author.login // "") | test("copilot";"i"))
      | select(any(.comments.nodes[1:][]; .author.__typename == "User") | not)
      | {
          thread_id: .id,
          is_resolved: .isResolved,
          comment_id: .comments.nodes[0].databaseId,
          comment_url: .comments.nodes[0].url,
          path: .comments.nodes[0].path,
          line: .comments.nodes[0].line,
          body: .comments.nodes[0].body,
          reply_count: ([.comments.nodes[1:][]] | length)
        }]'
}

resolve_thread_id() {
  local -r thread_id="$1"
  # shellcheck disable=SC2016
  gh api graphql -f query='
mutation($id:ID!) {
  resolveReviewThread(input:{threadId:$id}) {
    thread { isResolved }
  }
}' -f id="${thread_id}" >/dev/null
}

cmd_check() {
  local repo pr owner name snapshot status satisfied unaddressed fresh merge_state pr_merged
  repo="$(resolve_repo "${1:-}")"
  read -r owner name < <(repo_parts "${repo}")
  pr="$(resolve_pr "${2:-}" "${repo}")"
  require_cmd gh
  require_cmd jq
  snapshot="$(graphql_pr_snapshot "${owner}" "${name}" "${pr}")"
  assert_snapshot_complete "${snapshot}"
  status="$(status_json_from_snapshot "${snapshot}" "${repo}" "${pr}")"
  pr_merged="$(printf '%s' "${status}" | jq -r '.pr_merged')"
  if [[ "${pr_merged}" == 'true' ]]; then
    printf '%s\n' "${status}"
    printf 'wait-for-copilot-review: PR #%s is merged — loop complete\n' "${pr}" >&2
    return 0
  fi
  satisfied="$(printf '%s' "${status}" | jq -r '.satisfied')"
  unaddressed="$(printf '%s' "${status}" | jq -r '.unaddressed_copilot_threads')"
  fresh="$(printf '%s' "${status}" | jq -r '.fresh_review_on_head')"
  merge_state="$(printf '%s' "${status}" | jq -r '.merge_state_status')"
  if [[ "${satisfied}" == 'true' ]]; then
    printf '%s\n' "${status}"
    return 0
  fi
  if [[ "${fresh}" != 'true' ]]; then
    printf '%s\n' "${status}"
    return 2
  fi
  if [[ "${unaddressed}" -gt 0 ]]; then
    printf '%s\n' "${status}" >&2
    threads_json_from_snapshot "${snapshot}"
    return 3
  fi
  if ! merge_state_ready "${merge_state}"; then
    printf '%s\n' "${status}"
    printf 'wait-for-copilot-review: mergeStateStatus=%s — run restack (BEHIND) or fix conflicts\n' \
      "${merge_state}" >&2
    return 4
  fi
  printf '%s\n' "${status}"
  return 0
}

cmd_resolve_thread() {
  local -r thread_id="${1:-}"
  if [[ -z "${thread_id}" ]]; then
    die "resolve-thread requires --thread-id"
  fi
  require_cmd gh
  resolve_thread_id "${thread_id}"
  printf 'Resolved thread %s\n' "${thread_id}" >&2
}

cmd_resolve_addressed() {
  local repo pr owner name ids id snapshot
  repo="$(resolve_repo "${1:-}")"
  read -r owner name < <(repo_parts "${repo}")
  pr="$(resolve_pr "${2:-}" "${repo}")"
  require_cmd gh
  require_cmd jq
  snapshot="$(graphql_pr_snapshot "${owner}" "${name}" "${pr}")"
  assert_snapshot_complete "${snapshot}"
  mapfile -t ids < <(
    printf '%s' "${snapshot}" \
      | jq -r '.data.repository.pullRequest.reviewThreads.nodes[]
        | select(.isResolved == false)
        | select((.comments.nodes[0].author.login // "") | test("copilot";"i"))
        | select(any(.comments.nodes[1:][]; .author.__typename == "User"))
        | .id'
  )
  if ((${#ids[@]} == 0)); then
    printf 'No addressed Copilot threads to resolve on PR #%s\n' "${pr}" >&2
    return 0
  fi
  for id in "${ids[@]}"; do
    resolve_thread_id "${id}"
    printf 'Resolved thread %s\n' "${id}" >&2
  done
}

cmd_restack() {
  local repo pr merge_state head_branch pr_head_branch attempt base_branch
  repo="$(resolve_repo "${1:-}")"
  pr="$(resolve_pr "${2:-}" "${repo}")"
  require_cmd gh
  require_cmd gt
  require_cmd git
  if pr_is_merged "${repo}" "${pr}"; then
    printf 'PR #%s is already merged — skipping restack\n' "${pr}" >&2
    return 0
  fi
  assert_checkout_matches_repo "${repo}"
  assert_not_primary_worktree
  head_branch="$(gh pr view "${pr}" --repo "${repo}" --json headRefName --jq '.headRefName')"
  pr_head_branch="$(git branch --show-current 2>/dev/null || true)"
  if [[ -z "${pr_head_branch}" ]] || [[ "${pr_head_branch}" != "${head_branch}" ]]; then
    die "current branch ${pr_head_branch@Q} is not PR #${pr} head ${head_branch@Q}"
  fi
  merge_state="$(gh pr view "${pr}" --repo "${repo}" --json mergeStateStatus --jq '.mergeStateStatus')"
  if [[ "${merge_state}" != 'BEHIND' ]]; then
    printf 'PR #%s mergeStateStatus=%s (no restack needed)\n' "${pr}" "${merge_state}" >&2
    return 0
  fi
  base_branch="$(gh pr view "${pr}" --repo "${repo}" --json baseRefName --jq '.baseRefName')"
  printf 'PR #%s is BEHIND %s — running gt sync and gt restack…\n' "${pr}" "${base_branch}" >&2
  gt sync
  gt restack
  gt submit --no-interactive --publish
  attempt=0
  while (( attempt < 12 )); do
    merge_state="$(gh pr view "${pr}" --repo "${repo}" --json mergeStateStatus --jq '.mergeStateStatus')"
    if [[ "${merge_state}" != 'BEHIND' ]]; then
      printf 'After restack: mergeStateStatus=%s\n' "${merge_state}" >&2
      return 0
    fi
    sleep 5
    attempt=$((attempt + 1))
  done
  die 'PR is still BEHIND after restack (waited 60s for GitHub to refresh mergeability)'
}

pr_is_merged() {
  local -r repo="$1"
  local -r pr="$2"
  [[ "$(gh pr view "${pr}" --repo "${repo}" --json state --jq '.state')" == 'MERGED' ]]
}

pr_merge_json() {
  local -r repo="$1"
  local -r pr="$2"
  gh pr view "${pr}" --repo "${repo}" --json state,mergedAt,mergeStateStatus,mergeable,baseRefName
}

merge_state_ready() {
  local -r state="$1"
  case "${state}" in
    CLEAN|BLOCKED) return 0 ;;
    *) return 1 ;;
  esac
}

pr_title() {
  local -r repo="$1"
  local -r pr="$2"
  gh pr view "${pr}" --repo "${repo}" --json title --jq '.title'
}

send_email() {
  local -r subject_raw="$1"
  local subject
  shift
  subject="${subject_raw//$'\r'/}"
  subject="${subject//$'\n'/}"
  require_cmd sendmail
  {
    printf 'From: %s\n' "${from_addr}"
    printf 'To: %s\n' "${to_addr}"
    printf 'Subject: %s\n' "${subject}"
    printf 'Content-Type: text/plain; charset=UTF-8\n\n'
    cat
  } | sendmail -t -oi -f "${from_addr}"
}

cmd_email_success() {
  local repo pr title url
  repo="$(resolve_repo "${1:-}")"
  pr="$(resolve_pr "${2:-}" "${repo}")"
  require_cmd gh
  title="$(pr_title "${repo}" "${pr}")"
  url="$(gh pr view "${pr}" --repo "${repo}" --json url --jq '.url')"
  send_email "PR ready for review: ${title} (domesti-bot #${pr})" <<EOF
Henrique,

PR #${pr} is ready for your review:
${url}

Title: ${title}

Copilot: fresh review on current head with no unaddressed Copilot threads.
Merge: mergeStateStatus is CLEAN or BLOCKED.
Verify CI with \`gh pr checks ${pr}\` before merge.

EOF
  printf 'Sent success email for PR #%s\n' "${pr}" >&2
}

cmd_email_failure() {
  local repo pr title url reason
  repo="$(resolve_repo "${1:-}")"
  pr="$(resolve_pr "${2:-}" "${repo}")"
  reason="${3:-Copilot review loop exceeded the 30-minute total deadline.}"
  require_cmd gh
  title="$(pr_title "${repo}" "${pr}")"
  url="$(gh pr view "${pr}" --repo "${repo}" --json url --jq '.url')"
  send_email "PR review flow FAILED: ${title} (domesti-bot #${pr})" <<EOF
Henrique,

The automated Copilot review loop did not complete within 30 minutes.

PR #${pr}: ${url}
Title: ${title}

Reason: ${reason}

Please review manually on GitHub. Unresolved Copilot threads may still be open.

EOF
  printf 'Sent failure email for PR #%s\n' "${pr}" >&2
}

main() {
  local cmd="${1:-}"
  shift || true
  local repo_arg='' pr_arg='' timeout_arg='' interval_arg='' thread_id='' reason=''

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo)
        repo_arg="$(require_option_value --repo "${2:-}")"
        shift 2
        ;;
      --pr)
        pr_arg="$(require_option_value --pr "${2:-}")"
        shift 2
        ;;
      --timeout)
        timeout_arg="$(require_option_value --timeout "${2:-}")"
        shift 2
        ;;
      --poll-interval)
        interval_arg="$(require_option_value --poll-interval "${2:-}")"
        shift 2
        ;;
      --thread-id)
        thread_id="$(require_option_value --thread-id "${2:-}")"
        shift 2
        ;;
      --reason)
        reason="$(require_option_value --reason "${2:-}")"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done

  if [[ -n "${repo_arg}" && -z "${pr_arg}" && -z "${DOMESTI_PR_NUMBER:-}" ]]; then
    die "PR number required when --repo is set (pass --pr N or set DOMESTI_PR_NUMBER)"
  fi

  case "${cmd}" in
    status)
      cmd_status "${repo_arg}" "${pr_arg}"
      ;;
    request)
      cmd_request "${repo_arg}" "${pr_arg}"
      ;;
    wait)
      cmd_wait "${repo_arg}" "${pr_arg}" \
        "${timeout_arg:-${default_wait_timeout_s}}" \
        "${interval_arg:-${default_poll_interval_s}}"
      ;;
    list-threads)
      cmd_list_threads "${repo_arg}" "${pr_arg}"
      ;;
    check)
      cmd_check "${repo_arg}" "${pr_arg}"
      ;;
    restack)
      cmd_restack "${repo_arg}" "${pr_arg}"
      ;;
    resolve-thread)
      cmd_resolve_thread "${thread_id}"
      ;;
    resolve-addressed)
      cmd_resolve_addressed "${repo_arg}" "${pr_arg}"
      ;;
    email-success)
      cmd_email_success "${repo_arg}" "${pr_arg}"
      ;;
    email-failure)
      cmd_email_failure "${repo_arg}" "${pr_arg}" "${reason}"
      ;;
    ''|-h|--help|help)
      usage
      ;;
    *)
      die "unknown command: ${cmd} (run with --help)"
      ;;
  esac
}

main "$@"
