#!/usr/bin/env bash
#
# Launch the interactive REPL CLI for LAN device control.
#
# Usage:
#   ./scripts/device-manager [OPTIONS]
#
# See ``app/device_manager_cli.py`` for the full flag list.

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

cli_module="app.device_manager_cli"
cli_path="${repo_root}/app/device_manager_cli.py"
if [[ ! -f "$cli_path" ]]; then
  echo "device-manager: missing ${cli_path#"${repo_root}/"} in ${repo_root}" >&2
  exit 1
fi

if command -v uv >/dev/null 2>&1; then
  exec uv run python -m "$cli_module" "$@"
fi

venv_python="${repo_root}/.venv/bin/python"
if [[ -x "$venv_python" ]]; then
  exec "$venv_python" -m "$cli_module" "$@"
fi

echo "device-manager: install uv (https://docs.astral.sh/uv/) or run 'uv sync' in ${repo_root}" >&2
exit 1
